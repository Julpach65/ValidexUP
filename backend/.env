# Validex UP - Environment Variables
PROJECT_NAME="Validex UP"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security (Change in production!)
SECRET_KEY="validex-super-secret-key-for-development-only-change-in-prod"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration (MySQL)
# Formato: mysql+pymysql://USUARIO:PASSWORD@localhost:3306/validex_db
DATABASE_URL="mysql+pymysql://root:123456@localhost:3306/ValidexDB"


# Twilio Configuration (Fase 2)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""
MOCK_SMS=True
